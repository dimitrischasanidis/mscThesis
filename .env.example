# Parliament stack — environment variables
# Copy to .env and uncomment/override as needed.
# Defaults shown here match local dev behavior (no .env needed locally).

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=parliament
POSTGRES_USER=parliament
POSTGRES_PASSWORD=parliament

# ── PDF cache directory (host path bind-mounted into containers) ───────────────
# Default: ./pdfs  (relative to compose project dir)
# On barad-dur server: point to the NAS to avoid filling the NVMe
#PDFS_HOST_DIR=/mnt/nas_storage/parliament/pdfs

# ── Scraper polling ───────────────────────────────────────────────────────────
SCRAPER_POLL_INTERVAL_S=3600
LOOKBACK_DAYS=30

# ── Downloader / Extractor polling ────────────────────────────────────────────
INGEST_POLL_INTERVAL_S=60
BATCH_SIZE=50
